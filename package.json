{
  "name": "mobile-proto",
  "version": "1.0.1",
  "description": "Wrap any mobile-first web app in a realistic phone frame for desktop & tablet viewers. Zero dependencies beyond React.",
  "keywords": [
    "react",
    "mobile",
    "prototype",
    "phone-frame",
    "iphone",
    "device-preview",
    "responsive",
    "mobile-preview"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/MobileFrameWrapper.css"
  },
  "files": [
    "dist",
    "src",
    "screenshots",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/components/MobileFrameWrapper.css dist/MobileFrameWrapper.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "screenshots": "npx playwright install chromium && node scripts/capture-screenshots.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
